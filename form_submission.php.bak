<?php
require_once 'includes/db.php';

if (!isset($_SESSION['student_id'])) {
  header('Location: login.php'); exit;
}

$student_id = (int)$_SESSION['student_id'];

// Ensure step rows exist (safety)
$ensure = $conn->prepare("
  INSERT IGNORE INTO student_step_status (student_id, step_id, status)
  SELECT ?, st.id, 'waiting'
  FROM admission_steps st
  WHERE st.is_active = 1
");
$ensure->bind_param('i', $student_id);
$ensure->execute();
$ensure->close();

// Read-only meta (top alert)
$student = [
  'gst_roll' => $_SESSION['student_gst'] ?? '',
  'dept'     => $_SESSION['student_dept'] ?? '',
  'merit'    => $_SESSION['student_merit'] ?? '',
];

// Load existing form (for edit)
$existing = $conn->prepare("SELECT * FROM admission_forms WHERE student_id = ? LIMIT 1");
$existing->bind_param('i', $student_id);
$existing->execute();
$form = $existing->get_result()->fetch_assoc() ?: [];
$existing->close();

$error = '';

function save_photo($oldValue = null) {
  if (!isset($_FILES['photo']) || $_FILES['photo']['error'] === UPLOAD_ERR_NO_FILE) {
    return $oldValue ?: null;
  }
  if ($_FILES['photo']['error'] !== UPLOAD_ERR_OK) {
    return $oldValue ?: null;
  }

  $ext = strtolower(pathinfo($_FILES['photo']['name'], PATHINFO_EXTENSION));
  if (!in_array($ext, ['jpg','jpeg','png'], true)) {
    return $oldValue ?: null;
  }

  if (!is_dir('uploads')) {
    @mkdir('uploads', 0755, true);
  }

  $newName = 'photo_' . time() . '_' . bin2hex(random_bytes(4)) . '.' . $ext;
  $dest = 'uploads/' . $newName;

  if (move_uploaded_file($_FILES['photo']['tmp_name'], $dest)) {
    return $dest;
  }
  return $oldValue ?: null;
}

if ($_SERVER['REQUEST_METHOD'] === 'POST') {

  // Text fields
  $full_name = trim($_POST['full_name'] ?? '');
  $father_name = trim($_POST['father_name'] ?? '');
  $mother_name = trim($_POST['mother_name'] ?? '');
  $dob = trim($_POST['dob'] ?? '');
  $gender = trim($_POST['gender'] ?? '');
  $blood_group = trim($_POST['blood_group'] ?? '');
  $nationality = trim($_POST['nationality'] ?? '');
  $religion = trim($_POST['religion'] ?? '');
  $nid = trim($_POST['nid'] ?? '');

  $present_address = trim($_POST['present_address'] ?? '');
  $permanent_address = trim($_POST['permanent_address'] ?? '');
  $district = trim($_POST['district'] ?? '');
  $division = trim($_POST['division'] ?? '');
  $postal_code = trim($_POST['postal_code'] ?? '');

  $ssc_roll = trim($_POST['ssc_roll'] ?? '');
  $ssc_reg  = trim($_POST['ssc_reg'] ?? '');
  $ssc_year = (int)($_POST['ssc_year'] ?? 0);

  $hsc_roll = trim($_POST['hsc_roll'] ?? '');
  $hsc_reg  = trim($_POST['hsc_reg'] ?? '');
  $hsc_year = (int)($_POST['hsc_year'] ?? 0);

  $quota = trim($_POST['quota'] ?? '');

  $guardian_name = trim($_POST['guardian_name'] ?? '');
  $guardian_relation = trim($_POST['guardian_relation'] ?? '');
  $guardian_phone = trim($_POST['guardian_phone'] ?? '');
  $guardian_occupation = trim($_POST['guardian_occupation'] ?? '');
  $annual_income = trim($_POST['annual_income'] ?? '');

  $agree = isset($_POST['agree']);

  // Basic validation
  if (
    $full_name === '' || $father_name === '' || $mother_name === '' || $dob === '' ||
    $gender === '' || $blood_group === '' || $nationality === '' || $religion === '' || $nid === '' ||
    $present_address === '' || $permanent_address === '' || $district === '' || $division === '' || $postal_code === '' ||
    $ssc_roll === '' || $ssc_reg === '' || !$ssc_year ||
    $hsc_roll === '' || $hsc_reg === '' || !$hsc_year ||
    $quota === '' ||
    $guardian_name === '' || $guardian_relation === '' || $guardian_phone === '' || $guardian_occupation === '' || $annual_income === ''
  ) {
    $error = "Please fill all required fields.";
  } elseif (!$agree) {
    $error = "You must accept the declaration.";
  } else {

    // Photo upload (keep old if not uploading)
    $photo = save_photo($form['photo'] ?? null);

    $sql = "
      INSERT INTO admission_forms (
        student_id,
        full_name, father_name, mother_name, dob, gender, blood_group, nationality, religion, nid,
        present_address, permanent_address, district, division, postal_code,
        ssc_roll, ssc_reg, ssc_year,
        hsc_roll, hsc_reg, hsc_year,
        quota,
        guardian_name, guardian_relation, guardian_phone, guardian_occupation, annual_income,
        photo
      )
      VALUES (
        ?, ?, ?, ?, ?, ?, ?, ?, ?, ?,
        ?, ?, ?, ?, ?,
        ?, ?, ?,
        ?, ?, ?,
        ?,
        ?, ?, ?, ?, ?,
        ?
      )
      ON DUPLICATE KEY UPDATE
        full_name=VALUES(full_name),
        father_name=VALUES(father_name),
        mother_name=VALUES(mother_name),
        dob=VALUES(dob),
        gender=VALUES(gender),
        blood_group=VALUES(blood_group),
        nationality=VALUES(nationality),
        religion=VALUES(religion),
        nid=VALUES(nid),
        present_address=VALUES(present_address),
        permanent_address=VALUES(permanent_address),
        district=VALUES(district),
        division=VALUES(division),
        postal_code=VALUES(postal_code),
        ssc_roll=VALUES(ssc_roll),
        ssc_reg=VALUES(ssc_reg),
        ssc_year=VALUES(ssc_year),
        hsc_roll=VALUES(hsc_roll),
        hsc_reg=VALUES(hsc_reg),
        hsc_year=VALUES(hsc_year),
        quota=VALUES(quota),
        guardian_name=VALUES(guardian_name),
        guardian_relation=VALUES(guardian_relation),
        guardian_phone=VALUES(guardian_phone),
        guardian_occupation=VALUES(guardian_occupation),
        annual_income=VALUES(annual_income),
        photo=VALUES(photo)
    ";

    $stmt = $conn->prepare($sql);
    if (!$stmt) {
      $error = "SQL Prepare failed: " . $conn->error;
    } else {

      // ✅ FIXED TYPES (28 vars total)
      // i + 16s + i + 2s + i + 7s = 28
      $types = 'i' . str_repeat('s', 16) . 'i' . str_repeat('s', 2) . 'i' . str_repeat('s', 7);

      $stmt->bind_param(
        $types,
        $student_id,

        // 16 strings (full_name -> ssc_reg)
        $full_name, $father_name, $mother_name, $dob, $gender, $blood_group, $nationality, $religion, $nid,
        $present_address, $permanent_address, $district, $division, $postal_code,
        $ssc_roll, $ssc_reg,

        // int
        $ssc_year,

        // 2 strings
        $hsc_roll, $hsc_reg,

        // int
        $hsc_year,

        // 7 strings (quota + guardian 5 + photo)
        $quota,
        $guardian_name, $guardian_relation, $guardian_phone, $guardian_occupation, $annual_income,
        $photo
      );

      $stmt->execute();
      $stmt->close();

      // Mark step 1 as DONE (student can still edit anytime)
      $upd1 = $conn->prepare("
        UPDATE student_step_status ss
        JOIN admission_steps st ON st.id = ss.step_id
        SET ss.status = 'done'
        WHERE ss.student_id = ? AND st.step_order = 1
      ");
      $upd1->bind_param('i', $student_id);
      $upd1->execute();
      $upd1->close();

      header("Location: dashboard.php");
      exit;
    }
  }
}

$page_title = 'Form Submission';
